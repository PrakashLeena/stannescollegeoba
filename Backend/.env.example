# MongoDB
MONGODB_URI="mongodb+srv://USER:PASS@CLUSTER.mongodb.net/DBNAME?retryWrites=true&w=majority"
MONGODB_DB="DBNAME"

# NextAuth
NEXTAUTH_URL="http://localhost:3001"
NEXTAUTH_SECRET="replace-with-a-long-random-secret"

# Admin email notifications
ADMIN_EMAIL="stannesppa.official@gmail.com"
MAIL_FROM="stannesppa.official@gmail.com"

# SMTP (used by Nodemailer)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="465"
SMTP_USER="stannesppa.official@gmail.com"
SMTP_PASS="your-app-password"

# Cloudinary (gallery image upload)
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# Token to protect POST /api/mail
MAIL_API_TOKEN="replace-with-strong-random-token"

# Optional seed credentials
SEED_ADMIN_EMAIL="stannesppa.official@gmail.com"
SEED_ADMIN_PASSWORD="change-me"
